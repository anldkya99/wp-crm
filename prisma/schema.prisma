generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM_LEAD
  OPERATOR
}

enum PlatformRole {
  OP_CEO
  COMPANY_BOSS
  COMPANY_ADMIN
  DEPARTMENT_ADMIN
  OPERATOR
}

enum UserStatus {
  ACTIVE
  PASSIVE
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  WAITING
  COMPLETED
  CLOSED
}

enum ConversationStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  CLOSED
}

enum SenderType {
  CUSTOMER
  OPERATOR
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum AlarmStatus {
  PENDING
  SNOOZED
  COMPLETED
  CLOSED
}

model User {
  id                    String         @id @default(cuid())
  name                  String
  email                 String         @unique
  passwordHash          String         @map("password_hash")
  role                  UserRole       @default(OPERATOR)
  platformRole          PlatformRole   @default(OPERATOR) @map("platform_role")
  status                UserStatus     @default(ACTIVE)
  ttsDailyLimit         Int            @default(50) @map("tts_daily_limit")
  companyId             String?        @map("company_id")
  departmentId          String?        @map("department_id")
  teamLeadId            String?        @map("team_lead_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  requests              Request[]      @relation("RequestCreator")
  assignedConversations Conversation[] @relation("AssignedOperator")
  messages              Message[]      @relation("MessageCreator")
  taskNotes             TaskNote[]
  customerNotes         CustomerNote[]
  ttsUsageLogs          TtsUsageLog[]  @relation("TtsOperator")
  timelineEvents        TimelineEvent[] @relation("TimelineOperator")
  lineSessions          OperatorLineSession[]
  company               Company?       @relation(fields: [companyId], references: [id])
  department            Department?    @relation(fields: [departmentId], references: [id])
  teamLead              User?          @relation("TeamLeadMembers", fields: [teamLeadId], references: [id])
  teamMembers           User[]         @relation("TeamLeadMembers")

  @@map("users")
}

model Company {
  id              String               @id @default(cuid())
  name            String
  slug            String               @unique
  status          String               @default("active")
  companyType     String               @default("standard") @map("company_type")
  industryProfile String               @default("custom") @map("industry_profile")
  licensePackage  String               @default("starter") @map("license_package")
  licenseStatus   String               @default("active") @map("license_status")
  country         String               @default("TR")
  timezone        String               @default("Europe/Istanbul")
  language        String               @default("tr")
  currency        String               @default("TRY")
  logoUrl         String?              @map("logo_url")
  createdBy       String?              @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  users           User[]
  departments     Department[]
  modules         CompanyModule[]
  capabilities    CompanyCapability[]
  featureFlags    CompanyFeatureFlag[]
  settings        CompanySetting[]
  configurationVersions ConfigurationVersion[]
  permissionGrants CompanyPermissionGrant[]
  auditLogs       CompanyAuditLog[]

  @@map("companies")
}

model Department {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  slug      String
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]

  @@unique([companyId, slug])
  @@map("departments")
}

model CompanyModule {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  moduleId           String   @map("module_id")
  name               String
  version            String
  navigationGroup    String   @map("navigation_group")
  permissionGroup    String   @map("permission_group")
  licenseRequirement String   @map("license_requirement")
  featureFlag        String?  @map("feature_flag")
  auditEnabled       Boolean  @default(false) @map("audit_enabled")
  dependenciesJson   Json     @default("[]") @map("dependencies_json")
  defaultEnabled     Boolean  @default(false) @map("default_enabled")
  enabled            Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@map("company_modules")
}

model CompanyCapability {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  moduleId           String   @map("module_id")
  capabilityId       String   @map("capability_id")
  name               String
  version            String
  category           String
  permissionGroup    String   @map("permission_group")
  licenseRequirement String   @map("license_requirement")
  featureFlagsJson   Json     @default("[]") @map("feature_flags_json")
  dependenciesJson   Json     @default("[]") @map("dependencies_json")
  defaultEnabled     Boolean  @default(false) @map("default_enabled")
  enabled            Boolean  @default(false)
  lifecycleState     String   @default("registered") @map("lifecycle_state")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, capabilityId])
  @@index([moduleId])
  @@map("company_capabilities")
}

model CompanyFeatureFlag {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  key       String
  enabled   Boolean  @default(false)
  source    String   @default("provisioning")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@map("company_feature_flags")
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  key       String
  valueJson Json     @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@map("company_settings")
}

model ConfigurationVersion {
  id                 String   @id @default(cuid())
  configurationId    String   @map("configuration_id")
  scope              String
  companyId          String?  @map("company_id")
  departmentId       String?  @map("department_id")
  operatorId         String?  @map("operator_id")
  previousValueJson  Json?    @map("previous_value_json")
  newValueJson       Json     @map("new_value_json")
  changedBy          String?  @map("changed_by")
  version            Int
  createdAt          DateTime @default(now()) @map("created_at")
  company            Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([configurationId, scope])
  @@index([companyId, configurationId])
  @@map("configuration_versions")
}

model CompanyPermissionGrant {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  platformRole PlatformRole @map("platform_role")
  permission String
  createdAt  DateTime @default(now()) @map("created_at")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platformRole, permission])
  @@map("company_permission_grants")
}

model CompanyAuditLog {
  id        String   @id @default(cuid())
  companyId String?  @map("company_id")
  actorId   String?  @map("actor_id")
  eventType String   @map("event_type")
  message   String
  metadataJson Json? @map("metadata_json")
  createdAt DateTime @default(now()) @map("created_at")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([eventType])
  @@map("company_audit_logs")
}

model Contact {
  id            String         @id @default(cuid())
  name          String
  phone         String         @unique
  gender        String?
  note          String?
  firstName     String?        @map("first_name")
  lastName      String?        @map("last_name")
  username      String?
  nationalId    String?        @map("national_id")
  memberStatus  String         @default("Aktif") @map("member_status")
  source        String         @default("Manuel")
  isRegistered  Boolean        @default(true) @map("is_registered")
  ownerOperatorId String?      @map("owner_operator_id")
  ownershipStatus String       @default("pool") @map("ownership_status")
  assignedAt    DateTime?      @map("assigned_at")
  lastContactAt DateTime?      @map("last_contact_at")
  assignedByAdminId String?    @map("assigned_by_admin_id")
  ownershipNotes String?       @map("ownership_notes")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  tagRelations  MemberTagRelation[]
  requests      Request[]
  conversations Conversation[]
  dailyTasks    DailyTask[]
  customerNotes CustomerNote[]
  ttsUsageLogs  TtsUsageLog[]
  timelineEvents TimelineEvent[]
  ownershipRequests ContactOwnershipRequest[]

  @@map("contacts")
}

model ContactOwnershipRequest {
  id                String   @id @default(cuid())
  contactId         String   @map("contact_id")
  customerPhone     String   @map("customer_phone")
  requestedById     String?  @map("requested_by_operator_id")
  currentOwnerId    String?  @map("current_owner_operator_id")
  status            String   @default("pending")
  note              String?
  decisionNote      String?  @map("decision_note")
  decidedById       String?  @map("decided_by_admin_id")
  decidedAt         DateTime? @map("decided_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  contact           Contact  @relation(fields: [contactId], references: [id])

  @@map("contact_ownership_requests")
}

model Request {
  id                  String        @id @default(cuid())
  contactId           String        @map("contact_id")
  amount              Decimal       @db.Decimal(12, 2)
  status              RequestStatus @default(NEW)
  note                String?
  firstName           String?       @map("first_name")
  lastName            String?       @map("last_name")
  username            String?
  nationalId          String?       @map("national_id")
  phone               String?
  gender              String?
  requestType         String        @default("Bonus") @map("request_type")
  bonusAmount         Decimal?      @map("bonus_amount") @db.Decimal(12, 2)
  bonusDescription    String?       @map("bonus_description")
  giftAmount          Decimal?      @map("gift_amount") @db.Decimal(12, 2)
  giftDescription     String?       @map("gift_description")
  correctionDirection String?       @map("correction_direction")
  correctionAmount    Decimal?      @map("correction_amount") @db.Decimal(12, 2)
  correctionDescription String?     @map("correction_description")
  betId               String?       @map("bet_id")
  gameName            String?       @map("game_name")
  betDescription      String?       @map("bet_description")
  commandText         String?       @map("command_text")
  createdBy           String?       @map("created_by")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  contact             Contact       @relation(fields: [contactId], references: [id])
  creator             User?         @relation("RequestCreator", fields: [createdBy], references: [id])

  @@map("requests")
}

model Conversation {
  id                 String             @id @default(cuid())
  contactId          String             @map("contact_id")
  lineId             String?            @map("line_id")
  assignedOperatorId String?            @map("assigned_operator_id")
  status             ConversationStatus @default(NEW)
  isArchived         Boolean            @default(false) @map("is_archived")
  isMuted            Boolean            @default(false) @map("is_muted")
  lastMessageAt      DateTime?          @map("last_message_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  contact            Contact            @relation(fields: [contactId], references: [id])
  line               CommunicationLine? @relation(fields: [lineId], references: [id])
  assignedOperator   User?              @relation("AssignedOperator", fields: [assignedOperatorId], references: [id])
  messages           Message[]

  @@map("conversations")
}

model Message {
  id             String        @id @default(cuid())
  conversationId String        @map("conversation_id")
  lineId         String?       @map("line_id")
  providerType   String?       @map("provider_type")
  providerMessageId String?    @map("provider_message_id")
  senderType     SenderType    @map("sender_type")
  messageText    String        @map("message_text")
  status         MessageStatus @default(SENT)
  createdBy      String?       @map("created_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  line           CommunicationLine? @relation(fields: [lineId], references: [id])
  creator        User?         @relation("MessageCreator", fields: [createdBy], references: [id])
  ttsUsageLogs   TtsUsageLog[]
  queueItems      MessageSendQueue[]

  @@unique([providerType, providerMessageId])
  @@index([lineId])
  @@map("messages")
}

model CommunicationLine {
  id              String    @id @default(cuid())
  name            String
  phoneNumber     String    @map("phone_number")
  countryCode     String    @default("+90") @map("country_code")
  providerType    String    @default("manual") @map("provider_type")
  status          String    @default("active")
  connectionStatus String   @default("disconnected") @map("connection_status")
  sessionPath     String?   @map("session_path")
  qrUpdatedAt     DateTime? @map("qr_updated_at")
  lastDisconnectedAt DateTime? @map("last_disconnected_at")
  lastError       String?   @map("last_error")
  isActiveOperationLine Boolean @default(false) @map("is_active_operation_line")
  isDefault       Boolean   @default(false) @map("is_default")
  lastConnectedAt DateTime? @map("last_connected_at")
  lastMessageAt   DateTime? @map("last_message_at")
  blockedAt       DateTime? @map("blocked_at")
  replacementOfLineId String? @map("replacement_of_line_id")
  replacedByLineId String? @map("replaced_by_line_id")
  archivedAt      DateTime? @map("archived_at")
  assignedOperatorId String? @map("assigned_operator_id")
  assignedAt      DateTime? @map("assigned_at")
  assignedByAdminId String? @map("assigned_by_admin_id")
  assignmentNote  String?   @map("assignment_note")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  messages        Message[]
  conversations   Conversation[]
  operatorSessions OperatorLineSession[]
  sessionLogs     WhatsAppSessionLog[]
  connectionSession CommunicationSession?
  connectionLogs   ConnectionActivityLog[]
  sendQueueItems   MessageSendQueue[]
  communicationEvents CommunicationEvent[]

  @@index([isDefault])
  @@map("communication_lines")
}

model CommunicationEvent {
  id          String   @id @default(cuid())
  lineId      String?  @map("line_id")
  providerType String  @map("provider_type")
  eventType   String   @map("event_type")
  providerMessageId String? @map("provider_message_id")
  contactPhone String? @map("contact_phone")
  payloadJson String?  @map("payload_json")
  status      String   @default("received")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  line        CommunicationLine? @relation(fields: [lineId], references: [id])

  @@unique([providerType, providerMessageId, eventType])
  @@index([lineId])
  @@index([providerType])
  @@index([eventType])
  @@index([createdAt])
  @@map("communication_events")
}

model MessageSendQueue {
  id          String   @id @default(cuid())
  messageId   String?  @map("message_id")
  lineId      String   @map("line_id")
  providerType String  @map("provider_type")
  recipientPhone String @map("recipient_phone")
  messageText String   @map("message_text")
  status      String   @default("queued")
  priority    Int      @default(5)
  attemptCount Int     @default(0) @map("attempt_count")
  maxAttempts  Int     @default(3) @map("max_attempts")
  scheduledAt DateTime? @map("scheduled_at")
  nextAttemptAt DateTime? @map("next_attempt_at")
  lockedAt    DateTime? @map("locked_at")
  lastError   String?  @map("last_error")
  providerMessageId String? @map("provider_message_id")
  metadataJson String? @map("metadata_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  sentAt      DateTime? @map("sent_at")
  message     Message? @relation(fields: [messageId], references: [id])
  line        CommunicationLine @relation(fields: [lineId], references: [id])

  @@index([lineId])
  @@index([providerType])
  @@index([status])
  @@index([priority])
  @@index([scheduledAt])
  @@index([nextAttemptAt])
  @@map("message_send_queue")
}

model WhatsAppSessionLog {
  id        String   @id @default(cuid())
  lineId    String   @map("line_id")
  eventType String   @map("event_type")
  status    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  line      CommunicationLine @relation(fields: [lineId], references: [id])

  @@index([lineId])
  @@index([eventType])
  @@index([createdAt])
  @@map("whatsapp_session_logs")
}

model CommunicationSession {
  id                    String   @id @default(cuid())
  lineId                String   @unique @map("line_id")
  providerType          String   @map("provider_type")
  sessionStatus         String   @default("disconnected") @map("session_status")
  qrCode                String?  @map("qr_code")
  lastQrAt              DateTime? @map("last_qr_at")
  connectedAt           DateTime? @map("connected_at")
  disconnectedAt        DateTime? @map("disconnected_at")
  lastHealthCheckAt     DateTime? @map("last_health_check_at")
  reconnectAttemptCount Int      @default(0) @map("reconnect_attempt_count")
  lastError             String?  @map("last_error")
  sessionStoragePath    String?  @map("session_storage_path")
  sessionKey            String?  @map("session_key")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  line                  CommunicationLine @relation(fields: [lineId], references: [id])

  @@index([providerType])
  @@index([sessionStatus])
  @@map("communication_sessions")
}

model ConnectionActivityLog {
  id          String   @id @default(cuid())
  lineId      String?  @map("line_id")
  providerType String  @map("provider_type")
  eventType   String   @map("event_type")
  status      String
  details     String?
  metadataJson String? @map("metadata_json")
  createdAt   DateTime @default(now()) @map("created_at")
  line        CommunicationLine? @relation(fields: [lineId], references: [id])

  @@index([lineId])
  @@index([providerType])
  @@index([eventType])
  @@index([createdAt])
  @@map("connection_activity_logs")
}

model OperatorLineSession {
  id          String            @id @default(cuid())
  operatorId  String            @map("operator_id")
  lineId      String            @map("line_id")
  slotNumber  Int               @map("slot_number")
  isActive    Boolean           @default(true) @map("is_active")
  openedAt    DateTime?         @map("opened_at")
  lastUsedAt  DateTime?         @map("last_used_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  operator    User              @relation(fields: [operatorId], references: [id])
  line        CommunicationLine @relation(fields: [lineId], references: [id])

  @@unique([operatorId, slotNumber])
  @@index([operatorId])
  @@index([lineId])
  @@map("operator_line_sessions")
}

model MessageTemplate {
  id        String   @id @default(cuid())
  title     String
  hashtag   String   @default("")
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("message_templates")
}

model VoiceTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("voice_templates")
}

model TtsUsageLog {
  id                   String   @id @default(cuid())
  operatorId           String?  @map("operator_id")
  memberId             String?  @map("member_id")
  messageId            String?  @map("message_id")
  messageText          String   @map("message_text")
  characterCount       Int      @map("character_count")
  estimatedTokenCount  Int      @map("estimated_token_count")
  audioDurationSeconds Float    @default(0) @map("audio_duration_seconds")
  provider             String
  model                String
  voice                String
  audioFileUrl         String   @map("audio_file_url")
  audioFileSizeBytes   Int      @default(0) @map("audio_file_size_bytes")
  fileSizeBytes        Int      @default(0) @map("file_size_bytes")
  status               String   @default("created")
  estimatedCostUsd     Decimal  @default(0) @map("estimated_cost_usd") @db.Decimal(10, 6)
  errorMessage         String?  @map("error_message")
  createdAt            DateTime @default(now()) @map("created_at")
  sentAt               DateTime? @map("sent_at")
  operator             User?    @relation("TtsOperator", fields: [operatorId], references: [id])
  member               Contact? @relation(fields: [memberId], references: [id])
  message              Message? @relation(fields: [messageId], references: [id])

  @@map("tts_usage_logs")
}

model DailyTask {
  id        String     @id @default(cuid())
  contactId String     @map("contact_id")
  title     String
  note      String?
  taskDate  DateTime   @map("task_date") @db.Date
  dueAt     DateTime?   @map("due_at")
  status    TaskStatus @default(PENDING)
  source    String      @default("Manuel")
  sourceReferenceId String? @map("source_reference_id")
  automationRuleKey String? @map("automation_rule_key")
  automationReason String? @map("automation_reason")
  automationQuestionsJson Json? @map("automation_questions_json")
  createdBy String?    @map("created_by")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  contact   Contact    @relation(fields: [contactId], references: [id])
  notes     TaskNote[]

  @@map("daily_tasks")
}

model MemberTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")
  relations MemberTagRelation[]

  @@map("member_tags")
}

model MemberTagRelation {
  id        String    @id @default(cuid())
  memberId  String    @map("member_id")
  tagId     String    @map("tag_id")
  createdAt DateTime  @default(now()) @map("created_at")
  member    Contact   @relation(fields: [memberId], references: [id])
  tag       MemberTag @relation(fields: [tagId], references: [id])

  @@unique([memberId, tagId])
  @@map("member_tag_relations")
}

model AutomationRuleSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(true)
  value     String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("automation_rule_settings")
}

model AutomationTaskLog {
  id          String   @id @default(cuid())
  ruleKey     String   @map("rule_key")
  memberId    String?  @map("member_id")
  taskId      String?  @map("task_id")
  taskTitle   String   @map("task_title")
  status      String
  explanation String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("automation_task_logs")
}

model AutomationDecisionLog {
  id                  String   @id @default(cuid())
  memberId            String?  @map("member_id")
  operatorId          String?  @map("operator_id")
  ruleKey             String   @map("rule_key")
  decisionType        String   @map("decision_type")
  reason              String
  questionAnswersJson Json     @map("question_answers_json")
  createdTaskId       String?  @map("created_task_id")
  completedTaskId     String?  @map("completed_task_id")
  referenceType       String?  @map("reference_type")
  referenceId         String?  @map("reference_id")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("automation_decision_logs")
}

model TaskNote {
  id        String    @id @default(cuid())
  taskId    String    @map("task_id")
  noteText  String    @map("note_text")
  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  task      DailyTask @relation(fields: [taskId], references: [id])
  creator   User?     @relation(fields: [createdBy], references: [id])

  @@map("task_notes")
}

model CustomerNote {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  noteText  String   @map("note_text")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  contact   Contact  @relation(fields: [contactId], references: [id])
  creator   User?    @relation(fields: [createdBy], references: [id])

  @@map("customer_notes")
}

model Alarm {
  id          String      @id @default(cuid())
  scheduledAt DateTime    @map("scheduled_at")
  note        String
  status      AlarmStatus @default(PENDING)
  createdBy   String?     @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("alarms")
}

model TimelineEvent {
  id               String   @id @default(cuid())
  memberId         String?  @map("member_id")
  operatorId       String?  @map("operator_id")
  eventType        String   @map("event_type")
  eventTitle       String   @map("event_title")
  eventDescription String?  @map("event_description")
  referenceType    String?  @map("reference_type")
  referenceId      String?  @map("reference_id")
  createdAt        DateTime @default(now()) @map("created_at")
  member           Contact? @relation(fields: [memberId], references: [id])
  operator         User?    @relation("TimelineOperator", fields: [operatorId], references: [id])

  @@index([memberId, createdAt])
  @@index([referenceType, referenceId])
  @@map("timeline_events")
}

